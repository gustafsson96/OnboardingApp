@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using OnboardingApp.Data
@using OnboardingApp.Models
@using ModuleModel = OnboardingApp.Models.Module

@inject AuthenticationStateProvider AuthStateProvider
@inject UserManager<ApplicationUser> UserManager
@inject ApplicationDbContext Db

<div class="sidebar">
    <div class="sidebar-header">
        <!-- Title and progress bar -->
        <h2 class="sidebar-title">Introduktion</h2>
        <p class="sidebar-subtitle">Övergripande framsteg</p>
        <div class="progress-track">
            <div class="progress-bar" style="width: @moduleProgressPercent%"></div>
        </div>

        <p class="progress-text">@completedModules av @totalModules moduler slutförda</p>
    </div>

    <hr class="sidebar-divider" />

    <SidebarSearch Modules="@modules" />

    <!-- Checklist section -->
    <nav class="sidebar-nav">
        <a href="/dashboard" class="nav-link active">Översikt</a>
        <a href="/checklista" class="nav-link">
            <div class="nav-link-text">
                <span>Checklista</span>
                <span class="nav-link-subtext">
                    @completedChecklistItems / @totalChecklistItems
                </span>
            </div>
        </a>
    </nav>

    <!-- Link to modules -->
    <div class="sidebar-modules">
    <p class="section-title">Moduler</p>
        @foreach (var module in modules)
            {
                <a href="/modul/@module.ModuleId" class="module-link">
                    @module.Title
                </a>
            }
    </div>

    <!-- Link to admin dashboard if role = admin -->
    @if (user?.IsInRole("Admin") == true)
    {
        <p class="section-title">Admin</p>
        <a href="/admin" class="nav-link">Adminpanel</a>
    }

    <!-- Profile section -->
    <div class="sidebar-user">
        <div class="user-avatar">@initials</div>
        <div class="user-info">
            <p class="user-name">@(fullName ?? "Användare")</p>
            <p class="user-action">Visa alternativ</p>
        </div>
    </div>
</div>

@code {
    private ClaimsPrincipal? user;
    private string? fullName;
    private string initials = "";
    private List<ModuleModel> modules = new();
    private int totalModules;
    private int completedModules;
    private int moduleProgressPercent;
    private int totalChecklistItems;
    private int completedChecklistItems;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
            return;

        var appUser = await UserManager.GetUserAsync(user);

        if (appUser is not null)
        {
            fullName = $"{appUser.FirstName} {appUser.LastName}".Trim();

            if (!string.IsNullOrWhiteSpace(appUser.FirstName))
                initials += appUser.FirstName[0];

            if (!string.IsNullOrWhiteSpace(appUser.LastName))
                initials += appUser.LastName[0];
        }

        string? userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        modules = await Db.Modules
            .Include(m => m.Sections)
            .OrderBy(m => m.OrderIndex)
            .ToListAsync();

        totalModules = modules.Count;

        completedModules = await Db.UserModuleProgresses
            .CountAsync(x => x.UserId == userId && x.IsCompleted);

        moduleProgressPercent = totalModules == 0
            ? 0
            : (int)Math.Round((double)completedModules / totalModules * 100);

        totalChecklistItems = await Db.ChecklistItems.CountAsync();

        completedChecklistItems = await Db.UserChecklistItemStatus.CountAsync(x => x.UserId == userId && x.Status == ChecklistStatus.Completed);
    }
}