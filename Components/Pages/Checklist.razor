@page "/checklist"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using OnboardingApp.Data
@using OnboardingApp.Models
@attribute [Authorize]

@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<h1>Checklista</h1>
<p>Här ser du alla moment i din inskolning.</p>

@if (isLoading)
{
    <p>Laddar...</p>
}
else
{
    <div class="filter-buttons">
        <button class="filter-button @(selectedCategory == "Alla" ? "active" : "")"
                @onclick='() => SetCategory("Alla")'>
            Alla
        </button>

        @foreach (string category in categories)
        {
            <button class="filter-button @(selectedCategory == category ? "active" : "")"
                    @onclick='() => SetCategory(category)'>
                @category
            </button>
        }
    </div>

    @if (filteredChecklistItems.Count == 0)
    {
        <p>Inga checklistpunkter hittades.</p>
    }
    else
    {
        <div class="checklist-container">
            @foreach (ChecklistItem item in filteredChecklistItems.OrderBy(i => i.OrderIndex))
            {
                <div class="checklist-card">
                    <h4>@item.Title</h4>

                    <div class="status-buttons">
                        <button class="status-btn @(GetStatus(item.ChecklistItemId) == ChecklistStatus.NotStarted ? "active" : "")"
                                @onclick='() => SetStatus(item.ChecklistItemId, ChecklistStatus.NotStarted)'>
                            Inte påbörjad
                        </button>

                        <button class="status-btn @(GetStatus(item.ChecklistItemId) == ChecklistStatus.InProgress ? "active" : "")"
                                @onclick='() => SetStatus(item.ChecklistItemId, ChecklistStatus.InProgress)'>
                            Pågår
                        </button>

                        <button class="status-btn @(GetStatus(item.ChecklistItemId) == ChecklistStatus.Completed ? "active" : "")"
                                @onclick='() => SetStatus(item.ChecklistItemId, ChecklistStatus.Completed)'>
                            Klar
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(item.Description))
                    {
                        <p>@item.Description</p>
                    }

                    @if (!string.IsNullOrWhiteSpace(item.Category))
                    {
                        <small class="category">@item.Category</small>
                    }

                    <small class="status-text">
                        Status: @GetStatusLabel(item.ChecklistItemId)
                    </small>
                </div>
            }
        </div>
    }
}

@code {
    private List<ChecklistItem> checklistItems = new();
    private List<UserChecklistItemStatus> userStatuses = new();

    private bool isLoading = true;
    private string selectedCategory = "Alla";
    private string currentUserId = string.Empty;

    private List<string> categories => checklistItems
        .Where(i => !string.IsNullOrWhiteSpace(i.Category))
        .Select(i => i.Category!)
        .Distinct()
        .OrderBy(c => c)
        .ToList();

    private List<ChecklistItem> filteredChecklistItems =>
        selectedCategory == "Alla"
            ? checklistItems
            : checklistItems
                .Where(i => i.Category == selectedCategory)
                .ToList();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        if (user is null)
        {
            isLoading = false;
            return;
        }

        currentUserId = user.Id;

        checklistItems = await Db.ChecklistItems
            .OrderBy(i => i.OrderIndex)
            .ToListAsync();

        userStatuses = await Db.Set<UserChecklistItemStatus>()
            .Where(s => s.UserId == currentUserId)
            .ToListAsync();

        isLoading = false;
    }

    private void SetCategory(string category)
    {
        selectedCategory = category;
    }

    private ChecklistStatus GetStatus(int checklistItemId)
    {
        var status = userStatuses.FirstOrDefault(s => s.ChecklistItemId == checklistItemId);
        return status?.Status ?? ChecklistStatus.NotStarted;
    }

    private string GetStatusLabel(int checklistItemId)
    {
        return GetStatus(checklistItemId) switch
        {
            ChecklistStatus.NotStarted => "Inte påbörjad",
            ChecklistStatus.InProgress => "Pågår",
            ChecklistStatus.Completed => "Klar",
            _ => "Inte påbörjad"
        };
    }

    private async Task SetStatus(int checklistItemId, ChecklistStatus newStatus)
    {
        var existingStatus = userStatuses
            .FirstOrDefault(s => s.ChecklistItemId == checklistItemId);

        if (existingStatus is null)
        {
            existingStatus = new UserChecklistItemStatus
            {
                UserId = currentUserId,
                ChecklistItemId = checklistItemId,
                Status = newStatus
            };

            Db.Set<UserChecklistItemStatus>().Add(existingStatus);
            userStatuses.Add(existingStatus);
        }
        else
        {
            existingStatus.Status = newStatus;
        }

        await Db.SaveChangesAsync();
    }
}