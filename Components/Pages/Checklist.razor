@page "/checklista"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.EntityFrameworkCore
@using OnboardingApp.Data
@using OnboardingApp.Models

@* Restrict access to authenticated users *@
@attribute [Authorize]

@inject ApplicationDbContext Db
@inject UserManager<ApplicationUser> UserManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<h1>Checklista</h1>
<p>Här ser du alla moment i din inskolning.</p>

@* Message for loading when data is being fetched *@
@if (isLoading)
{
    <p>Laddar...</p>
}
else
{
    @* Checklist progress bar *@
    <ProgressBar Total="@TotalChecklistItems" Completed="@CompletedChecklistItems" />
        @* Clickable category cards with individual progress bars *@
        <div class="category-progress-container">
            @foreach (var category in categories)
            {
                <CategoryProgressCard
                    Category="@category"
                    Total="@GetTotalForCategory(category)"
                    Completed="@GetCompletedForCategory(category)"
                    IsActive="@(selectedCategory == category)"
                    OnCategoryClick="SetCategory"
                    Color="@GetCategoryColor(category)"
                    />
            }
    </div>
    
    @* Filter buttons based on categories *@
    <div class="filter-buttons">
        <button class="filter-button @(selectedCategory == "Alla" ? "active" : "")"
                @onclick='() => SetCategory("Alla")'>
            Alla
        </button>

        @foreach (string category in categories)
        {
            <button class="filter-button @(selectedCategory == category ? "active" : "")"
                    @onclick='() => SetCategory(category)'>
                @category
            </button>
        }
    </div>

    @* Message if no items match the selected filter *@
    @if (filteredChecklistItems.Count == 0)
    {
        <p>Inga checklistpunkter hittades.</p>
    }
    else
    {
        @* Checklist *@
        <div class="checklist-container">

            @* Loop through filtered checklist items and render one card per item *@
            @foreach (ChecklistItem item in filteredChecklistItems.OrderBy(i => i.OrderIndex))
            {
                <div class="checklist-card @(GetStatus(item.ChecklistItemId) == ChecklistStatus.Completed ? "completed" : "") @(GetStatus(item.ChecklistItemId) == ChecklistStatus.InProgress ? "in-progress" : "")">

                    @* Card header *@
                    <div class="checklist-card-header">

                        <input type="checkbox"
                            class="checklist-checkbox"
                            checked="@(GetStatus(item.ChecklistItemId) == ChecklistStatus.Completed)"
                            @onclick:stopPropagation
                            @onchange="(e) => HandleCheckboxChanged(item.ChecklistItemId, e)" />

                        <div class="checklist-card-title-area">
                            <h4>@item.Title</h4>
                        </div>

                        <div class="checklist-card-actions">
                            @* Show start toggle button if item is not completed *@
                            @if (GetStatus(item.ChecklistItemId) != ChecklistStatus.Completed)
                            {
                                <button type="button"
                                        class="start-btn"
                                        @onclick='() => ToggleStarted(item.ChecklistItemId)'
                                        aria-label="Toggle start status">

                                    @(GetStatus(item.ChecklistItemId) == ChecklistStatus.InProgress
                                        ? "Markera som ej påbörjad"
                                        : "Markera som påbörjad")
                                </button>
                            }
                            @* Button with icon to toggle note panel for a checklist item *@
                            <button type="button"
                                    class="note-icon-btn @(IsNoteOpen(item.ChecklistItemId) ? "active" : "")"
                                    @onclick:stopPropagation
                                    @onclick='() => ToggleNote(item.ChecklistItemId)'
                                    aria-label="Öppna anteckningar">
                                <i class="fa-regular fa-pen-to-square"></i>
                            </button>
                        </div>
                    </div>

                    @* Checklist item description *@
                    @if (!string.IsNullOrWhiteSpace(item.Description))
                    {
                        <p>@item.Description</p>
                    }
                    
                    @* Current status (controlled by user) *@
                    <small class="status-text">
                    @if (!string.IsNullOrWhiteSpace(item.Category))
                        {
                            <small class="category"
                                style="background-color:@GetCategoryColor(item.Category); color:white;">
                                @item.Category
                            </small>
                        }
                        Status: @GetStatusLabel(item.ChecklistItemId)
                    </small>

                @* Render note panel when opened *@
                @if (IsNoteOpen(item.ChecklistItemId))
                {
                    <div class="note-panel">
                        <div class="note-divider"></div>

                        <div class="note-heading">
                            <span>Personliga anteckningar:</span>
                        </div>
                        <textarea id="note-@item.ChecklistItemId"
                                class="note-textarea"
                                placeholder="Skriv dina anteckningar här..."
                                @bind="BindNote[item.ChecklistItemId]"
                                @bind:event="oninput"
                                @onblur="() => SaveNote(item.ChecklistItemId)">
                        </textarea>
                        <p class="note-helper-text">Dina anteckningar sparas automatiskt</p>
                    </div>
                    }
                </div>
            }
        </div>
    }
}

@code {
    // Store checklist items fetched from database
    private List<ChecklistItem> checklistItems = new();

    // Store the current user's saved status for checklist items
    private List<UserChecklistItemStatus> userStatuses = new();

    // Stores the current user's saved notes for checklist items
    private List<UserNote> userNotes = new();

    // Holds the note text in memory for each checklist item while the user is editing
    private Dictionary<int, string> BindNote = new();

    private bool isLoading = true;

    // Track currently selected category filter
    private string selectedCategory = "Alla";

    // Store id of authenticated user
    private string currentUserId = string.Empty;

    // Returns the total number of checklist items
    private int TotalChecklistItems => checklistItems.Count;

    // Returns the number of checklist items marked as completed by the user
    private int CompletedChecklistItems => userStatuses
        .Count(s => s.Status == ChecklistStatus.Completed);

    // Store checklist item id for what note panel is currently open (null means that no panel is open)
    private int? openNoteForChecklistItemId = null;

    // Open the note panel for a selected item or close if it is open
    private void ToggleNote(int checklistItemId)
    {
        if (openNoteForChecklistItemId == checklistItemId)
        {
            openNoteForChecklistItemId = null;
        }
        else
        {
            openNoteForChecklistItemId = checklistItemId;
        }
    }

    private bool IsNoteOpen(int checklistItemId)
    {
        return openNoteForChecklistItemId == checklistItemId;
    }

    // Returns an ordered list of all available categories in the checklist
    private List<string> categories => checklistItems
        .Where(i => !string.IsNullOrWhiteSpace(i.Category))
        .Select(i => i.Category!)
        .Distinct()
        .OrderBy(c => c)
        .ToList();

    // Returns either all checklist items or those matching selected category
    private List<ChecklistItem> filteredChecklistItems =>
        selectedCategory == "Alla"
            ? checklistItems
            : checklistItems
                .Where(i => i.Category == selectedCategory)
                .ToList();

    // Runs when component is initialized
    // Loads the current user, checklist items, item status and existing notes 
    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = await UserManager.GetUserAsync(authState.User);

        // Stop loading if no authenticated user is found
        if (user is null)
        {
            isLoading = false;
            return;
        }

        currentUserId = user.Id;

        // Load all checklist items
        checklistItems = await Db.ChecklistItems
            .OrderBy(i => i.OrderIndex)
            .ToListAsync();

        // Load all saved statuses for the current user
        userStatuses = await Db.Set<UserChecklistItemStatus>()
            .Where(s => s.UserId == currentUserId)
            .ToListAsync();
        
        // Load all saved checklist notes belonging to the current user 
        userNotes = await Db.Set<UserNote>()
            .Where(n => n.UserId == currentUserId && n.ChecklistItemId != null)
            .ToListAsync();

        // Populate the note binding dictionary with existing saved notes
        foreach (var note in userNotes)
        {
            if (note.ChecklistItemId.HasValue)
            {
                BindNote[note.ChecklistItemId.Value] = note.Content;
            }
        }

        // Ensure every checklist item has a dictionary entry even if no note exist yet
        foreach (var item in checklistItems)
        {
            if (!BindNote.ContainsKey(item.ChecklistItemId))
            {
                BindNote[item.ChecklistItemId] = string.Empty;
            }
        }

        isLoading = false;
    }

    // Updates the currently selected category filter
    private void SetCategory(string category)
    {
        selectedCategory = category;
    }

    // Returns the current user's saved status for a checklist item
    private ChecklistStatus GetStatus(int checklistItemId)
    {
        var status = userStatuses.FirstOrDefault(s => s.ChecklistItemId == checklistItemId);
        return status?.Status ?? ChecklistStatus.NotStarted;
    }

    // Convert enum states into readable text 
    private string GetStatusLabel(int checklistItemId)
    {
        return GetStatus(checklistItemId) switch
        {
            ChecklistStatus.NotStarted => "Inte påbörjad",
            ChecklistStatus.InProgress => "Pågår",
            ChecklistStatus.Completed => "Klar",
            _ => "Inte påbörjad"
        };
    }

    // Returns total number of checklist items in a given category
    private int GetTotalForCategory(string category) =>
    checklistItems.Count(i => i.Category == category);

    // Returns how many checklist items in a given category are marked as completed
    private int GetCompletedForCategory(string category)
    {
        var categoryItemIds = checklistItems
            .Where(i => i.Category == category)
            .Select(i => i.ChecklistItemId)
            .ToList();

        return userStatuses.Count(s =>
            categoryItemIds.Contains(s.ChecklistItemId) &&
            s.Status == ChecklistStatus.Completed);
    }

    // Creates or updates the current user's status for a specific item
    private async Task SetStatus(int checklistItemId, ChecklistStatus newStatus)
    {
        var existingStatus = userStatuses
            .FirstOrDefault(s => s.ChecklistItemId == checklistItemId);

        if (existingStatus is null)
        {
            existingStatus = new UserChecklistItemStatus
            {
                UserId = currentUserId,
                ChecklistItemId = checklistItemId,
                Status = newStatus
            };

            Db.Set<UserChecklistItemStatus>().Add(existingStatus);
            userStatuses.Add(existingStatus);
        }
        else
        {
            existingStatus.Status = newStatus;
        }

        await Db.SaveChangesAsync();
    }

    // Toggle started status
    private async Task ToggleStarted(int checklistItemId)
    {
        var currentStatus = GetStatus(checklistItemId);

        if (currentStatus == ChecklistStatus.NotStarted)
        {
            await SetStatus(checklistItemId, ChecklistStatus.InProgress);
        }
        else if (currentStatus == ChecklistStatus.InProgress)
        {
            await SetStatus(checklistItemId, ChecklistStatus.NotStarted);
        }
    }

    // Set status for when checkbox is clicked 
    private async Task HandleCheckboxChanged(int checklistItemId, ChangeEventArgs e)
    {
        bool isChecked = (bool)e.Value!;

        if (isChecked)
        {
            await SetStatus(checklistItemId, ChecklistStatus.Completed);
        }
        else
        {
            await SetStatus(checklistItemId, ChecklistStatus.NotStarted);
        }
    }

    // Returns the saved note text for a checklist item
    private string GetNote(int checklistItemId)
    {
        return userNotes
            .FirstOrDefault(n => n.ChecklistItemId == checklistItemId)
            ?.Content ?? string.Empty;
    }

    // Creates or updates the current user's personal note for a checklist item
    private async Task SaveNote(int checklistItemId)
    {
        var content = BindNote.ContainsKey(checklistItemId)
            ? BindNote[checklistItemId]
            : "";

        var existingNote = userNotes
            .FirstOrDefault(n => n.ChecklistItemId == checklistItemId);

        if (existingNote is null)
        {
            existingNote = new UserNote
            {
                UserId = currentUserId,
                ChecklistItemId = checklistItemId,
                Content = content,
                CreatedAt = DateTime.UtcNow
            };

            Db.Set<UserNote>().Add(existingNote);
            userNotes.Add(existingNote);
        }
        else
        {
            existingNote.Content = content;
            existingNote.UpdatedAt = DateTime.UtcNow;
        }

        await Db.SaveChangesAsync();
    }

    // Color mapping for categories
    private Dictionary<string, string> categoryColors = new()
    {
        { "Bad", "#3b82f6" }, 
        { "Reception", "#10b981" }, 
        { "Spa", "#f59e0b" },
    };

    // Fallback color
    private string GetCategoryColor(string? category)
    {
        if (category != null && categoryColors.ContainsKey(category))
            return categoryColors[category];

        return "#9ca3af";
    }
}