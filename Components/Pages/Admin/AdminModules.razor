@page "/admin/moduler"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.EntityFrameworkCore
@using OnboardingApp.Data
@using OnboardingApp.Models
@attribute [Authorize(Roles = "Admin")]
@inject ApplicationDbContext Db

<h1>Hantera moduler</h1>
<p>Endast administratörer kan visa denna sida.</p>

@if (!string.IsNullOrWhiteSpace(message))
{
    <p>@message</p>
}

<h2>Skapa ny modul</h2>

<div>
    <div>
        <label for="title">Titel</label><br />
        <input id="title" @bind="newModule.Title" />
    </div>

    <div>
        <label for="description">Beskrivning</label><br />
        <textarea id="description" @bind="newModule.Description"></textarea>
    </div>

    <button @onclick="CreateModule">Skapa modul</button>
</div>

<hr />

<h2>Befintliga moduler</h2>

@if (modules.Count == 0)
{
    <p>Det finns inga moduler ännu.</p>
}
else
{
    @foreach (var module in modules)
    {
        var sectionForm = GetSectionForm(module.ModuleId);

        <div style="border:1px solid #ccc; padding:1em; margin-bottom:1em;">
            @if (editingModuleId == module.ModuleId)
            {
                <div>
                    <label>Titel</label><br />
                    <input @bind="editModule.Title" />
                </div>

                <div>
                    <label>Beskrivning</label><br />
                    <textarea @bind="editModule.Description"></textarea>
                </div>

                <div style="margin-top:0.5em;">
                    <button @onclick="SaveEdit">Spara</button>
                    <button @onclick="CancelEdit">Avbryt</button>
                </div>
            }
            else
            {
                <h3>@module.Title</h3>
                <p>@module.Description</p>
                <p><strong>Ordning:</strong> @module.OrderIndex</p>

                <button @onclick="() => StartEdit(module)">Redigera modul</button>
                <button @onclick="() => DeleteModule(module.ModuleId)">Ta bort modul</button>
            }

            <hr />

            <h4>Sektioner</h4>

            @if (module.Sections == null || !module.Sections.Any())
            {
                <p>Inga sektioner ännu.</p>
            }
            else
            {
                <ul>
                    @foreach (var section in module.Sections.OrderBy(s => s.OrderIndex))
                    {
                        <li>
                            <strong>@((MarkupString)section.Title):</strong>
                           @((MarkupString)section.Content)
                        </li>
                    }
                </ul>
            }

            <h4>Skapa ny sektion</h4>

            <div>
                <label>Titel</label><br />
                <input @bind="sectionForm.Title" />
            </div>

            <div>
                <label>Innehåll</label><br />
                <textarea @bind="sectionForm.Content"></textarea>
            </div>

            <div style="margin-top:0.5em;">
                <button @onclick="() => CreateSection(module.ModuleId)">Lägg till sektion</button>
            </div>
        </div>
    }
}

@code {
    private List<Module> modules = new();
    private Module newModule = new();
    private int? editingModuleId;
    private Module editModule = new();
    private string? message;

    // View model for a new section
    private class NewSectionModel
        {
            public string Title { get; set; } = string.Empty;
            public string Content { get; set; } = string.Empty;
        }
    
    // Section form for each module
    private Dictionary<int, NewSectionModel> newSections = new();

    // Fetch modules on page load
    protected override async Task OnInitializedAsync()
    {
        await LoadModules();
    }

    // Load all modules from db
    private async Task LoadModules()
    {
        modules = await Db.Modules
            .Include(m => m.Sections)
            .OrderBy(m => m.OrderIndex)
            .ToListAsync();
    }

    // Create module
    private async Task CreateModule()
    {
        if (string.IsNullOrWhiteSpace(newModule.Title))
        {
            message = "Titel måste anges.";
            return;
        }

        int maxOrderIndex = await Db.Modules
            .MaxAsync(m => (int?)m.OrderIndex) ?? 0;

        var module = new Module
        {
            Title = newModule.Title,
            Description = newModule.Description,
            OrderIndex = maxOrderIndex + 1
        };

        Db.Modules.Add(module);
        await Db.SaveChangesAsync();

        newModule = new Module();
        message = "Modulen skapades.";

        await LoadModules();
    }

    // Edit module
    private void StartEdit(Module module)
    {
        editingModuleId = module.ModuleId;

        editModule = new Module
        {
            ModuleId = module.ModuleId,
            Title = module.Title,
            Description = module.Description,
            OrderIndex = module.OrderIndex
        };
    }

    // Save edited module
    private async Task SaveEdit()
    {
        var module = await Db.Modules.FindAsync(editModule.ModuleId);

        if (module is null)
        {
            message = "Modulen kunde inte hittas.";
            return;
        }

        if (string.IsNullOrWhiteSpace(editModule.Title))
        {
            message = "Titel måste anges.";
            return;
        }

        module.Title = editModule.Title;
        module.Description = editModule.Description;
        module.OrderIndex = editModule.OrderIndex;

        await Db.SaveChangesAsync();

        editingModuleId = null;
        editModule = new Module();
        message = "Modulen uppdaterades.";

        await LoadModules();
    }

    // Cancel edit
    private void CancelEdit()
    {
        editingModuleId = null;
        editModule = new Module();
    }

    // Delete a module and its sections
    private async Task DeleteModule(int moduleId)
    {
        var module = await Db.Modules
            .Include(m => m.Sections)
            .FirstOrDefaultAsync(m => m.ModuleId == moduleId);

        if (module is null)
        {
            message = "Modulen kunde inte hittas.";
            return;
        }

        if (module.Sections.Any())
        {
            Db.ModuleSections.RemoveRange(module.Sections);
        }

        Db.Modules.Remove(module);
        await Db.SaveChangesAsync();

        message = "Modulen och dess sektioner togs bort.";
        await LoadModules();
    }

    // Get formdata for a module
    private NewSectionModel GetSectionForm(int moduleId)
        {
            if (!newSections.ContainsKey(moduleId))
            {
                newSections[moduleId] = new NewSectionModel();
            }

            return newSections[moduleId];
        }

    // Create a new section for a module
    private async Task CreateSection(int moduleId)
        {
            var form = GetSectionForm(moduleId);

            if (string.IsNullOrWhiteSpace(form.Title) || string.IsNullOrWhiteSpace(form.Content))
            {
                message = "Sektionens titel och innehåll måste anges.";
                return;
            }

            int maxOrderIndex = await Db.ModuleSections
                .Where(s => s.ModuleId == moduleId)
                .MaxAsync(s => (int?)s.OrderIndex) ?? 0;

            var section = new ModuleSection
            {
                ModuleId = moduleId,
                Title = form.Title,
                Content = form.Content,
                OrderIndex = maxOrderIndex + 1
            };

            Db.ModuleSections.Add(section);
            await Db.SaveChangesAsync();

            newSections[moduleId] = new NewSectionModel();
            message = "Sektionen skapades.";

            await LoadModules();
        }


}