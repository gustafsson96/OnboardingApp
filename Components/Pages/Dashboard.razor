@page "/dashboard"
@using System.Security.Claims
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using OnboardingApp.Data
@using OnboardingApp.Models
@using ModuleModel = OnboardingApp.Models.Module
@attribute [Authorize]

@inject ApplicationDbContext Db
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject UserManager<ApplicationUser> UserManager

@if (isLoading)
{
    <p>Laddar dashboard...</p>
}
else
{
    <h1>
        Välkommen@(string.IsNullOrWhiteSpace(firstName) ? "" : $", {firstName}")!
    </h1>
    <ModuleOverview
        TotalModules="@totalModules"
        CompletedModules="@completedModules"
        RemainingModules="@remainingModules" />
    <ProgressBar 
        Total="@totalChecklistItems" 
        Completed="@completedChecklistItems" />
    <ModuleCards
        Modules="@modules"
        UserProgresses="@moduleProgresses" />
}

@code {
    private bool isLoading = true;

    // Vairable to store name of user
    private string? firstName;

    // Module overview variables
    private int totalModules;
    private int completedModules;
    private int remainingModules;

    // Checklist variables
    private int totalChecklistItems;
    private int completedChecklistItems;

    // Module cards variables
    private List<ModuleModel> modules = new();
    private List<UserModuleProgress> moduleProgresses = new();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (user.Identity?.IsAuthenticated != true)
        {
            isLoading = false;
            return;
        }

        var appUser = await UserManager.GetUserAsync(user);
        firstName = appUser?.FirstName;

        string? userId = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;

        if (string.IsNullOrWhiteSpace(userId))
        {
            isLoading = false;
            return;
        }

        totalModules = await Db.Modules.CountAsync();

        completedModules = await Db.UserModuleProgresses
            .CountAsync(x => x.UserId == userId && x.IsCompleted);

        remainingModules = totalModules - completedModules;

        totalChecklistItems = await Db.ChecklistItems.CountAsync();

        completedChecklistItems = await Db.UserChecklistItemStatus
        .CountAsync(x => x.UserId == userId && x.Status == ChecklistStatus.Completed);

        modules = await Db.Modules
            .OrderBy(m => m.OrderIndex)
            .ToListAsync();

        moduleProgresses = await Db.UserModuleProgresses
            .Where(x => x.UserId == userId)
            .ToListAsync();

        isLoading = false;
    }
}