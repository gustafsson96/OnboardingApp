@page "/modul/{ModuleId:int}/quiz"
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using OnboardingApp.Data
@using OnboardingApp.Models
@using ModuleModel = OnboardingApp.Models.Module
@attribute [Authorize]
@inject ApplicationDbContext Db
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider

@if (isLoading)
{
    <p>Laddar quiz...</p>
}
else if (module is null)
{
    <p>Modulen kunde inte hittas.</p>
}
else
{
    <div class="quiz-page">
        <button class="back-button" @onclick="GoBack">
            ← Tillbaka till modul
        </button>

        <header class="quiz-header">
            <p class="quiz-kicker">Modulquiz</p>
            <h1>@module.Title</h1>

            @if (!string.IsNullOrWhiteSpace(module.Description))
            {
                <p class="quiz-description">@module.Description</p>
            }
        </header>

        <section class="quiz-card">
            <div class="quiz-card-top">
                <div>
                    <h2>Avslutande quiz</h2>
                    <p>
                        Besvara frågorna nedan för att slutföra modulen.
                    </p>
                </div>

                <span class="quiz-status-badge">
                    @questions.Count frågor
                </span>
            </div>

            @if (questions.Count == 0)
            {
                <div class="quiz-empty-state">
                    <h3>Inga quizfrågor ännu</h3>
                    <p>
                        Det finns inga frågor kopplade till den här modulen än.
                    </p>
                </div>
            }
            else
            {
                @foreach (var question in questions)
                {
                    <section class="question-card">
                        <div class="question-top">
                            <span class="question-number">@question.OrderIndex</span>
                            <h3>@question.QuestionText</h3>
                        </div>

                        <div class="options-list">
                            @foreach (var option in question.Options.OrderBy(o => o.QuizOptionId))
                            {
                                <label class="option-row @GetOptionCssClass(question, option)">
                                    <input type="radio"
                                           name="question-@question.QuizQuestionId"
                                           checked="@IsSelected(question.QuizQuestionId, option.QuizOptionId)"
                                           @onchange="() => SelectAnswer(question.QuizQuestionId, option.QuizOptionId)"
                                           disabled="@hasSubmitted" />

                                    <span>@option.OptionText</span>
                                </label>
                            }
                        </div>
                    </section>
                }

                <div class="quiz-actions">
                    <button class="submit-button"
                            disabled="@(!AllQuestionsAnswered || hasSubmitted)"
                            @onclick="SubmitQuiz">
                        Skicka
                    </button>
                </div>
                @if (hasSubmitted)
                {
                    <div class="quiz-result">
                        <h3>Resultat</h3>
                        <p>Du fick @score av @questions.Count rätt.</p>
                        <button class="show-answers-button" @onclick="ToggleShowAnswers">
                            @(showAnswers ? "Dölj svar" : "Visa svar")
                        </button>

                        <button class="retry-button" @onclick="RestartQuiz">
                            Gör quizet igen
                        </button>
                    </div>
                }
            }
        </section>
    </div>
}

@code {
    [Parameter]
    public int ModuleId { get; set; }

    private ModuleModel? module;
    private List<QuizQuestion> questions = new();
    private bool isLoading = true;
    private bool showAnswers = false;

    // Stores the selected answer for each question
    private Dictionary<int, int> selectedAnswers = new();

    private bool hasSubmitted = false;
    private int score = 0;

    // Checks if all questions have been answered
    private bool AllQuestionsAnswered =>
        questions.Count > 0 &&
        questions.All(q => selectedAnswers.ContainsKey(q.QuizQuestionId));

    protected override async Task OnParametersSetAsync()
    {
        isLoading = true;

        module = await Db.Modules
            .FirstOrDefaultAsync(m => m.ModuleId == ModuleId);

        questions = await Db.QuizQuestions
            .Where(q => q.ModuleId == ModuleId)
            .Include(q => q.Options)
            .OrderBy(q => q.OrderIndex)
            .ToListAsync();

        selectedAnswers.Clear();
        hasSubmitted = false;
        score = 0;
        showAnswers = false;

        isLoading = false;
    }

    // Saves the selected option for a question
    private void SelectAnswer(int questionId, int optionId)
    {
        selectedAnswers[questionId] = optionId;
    }

    // Checks if an option is currently selected
    private bool IsSelected(int questionId, int optionId)
    {
        return selectedAnswers.TryGetValue(questionId, out int selectedOptionId)
            && selectedOptionId == optionId;
    }

    // Calculates the quiz score
    private async Task SubmitQuiz()
    {
        score = questions.Count(q =>
            q.Options.Any(o =>
                o.IsCorrect &&
                selectedAnswers.TryGetValue(q.QuizQuestionId, out int selectedOptionId) &&
                selectedOptionId == o.QuizOptionId));

        hasSubmitted = true;

        // Get logged in user
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        if (!user.Identity?.IsAuthenticated ?? true)
            return;

        var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (userId is null)
            return;

        // Create QuizAttempt
        // A quiz is considered passed when all questions have been correctly answered
        var attempt = new QuizAttempt
        {
            ModuleId = ModuleId,
            UserId = userId,
            StartedAt = DateTime.UtcNow,
            CompletedAt = DateTime.UtcNow,
            Score = score,
            TotalQuestions = questions.Count,
            Passed = score == questions.Count 
        };

        Db.QuizAttempts.Add(attempt);
        await Db.SaveChangesAsync(); 

        // Save user's selected answers for a quiz attempt
        foreach (var q in questions)
        {
            if (selectedAnswers.TryGetValue(q.QuizQuestionId, out int selectedOptionId))
            {
                var answer = new QuizAnswer
                {
                    QuizAttemptId = attempt.QuizAttemptId,
                    QuizQuestionId = q.QuizQuestionId,
                    SelectedOptionId = selectedOptionId
                };

                Db.QuizAnswers.Add(answer);
            }
        }

        // If quiz is passed, update module progress
        if (attempt.Passed)
        {
            var progress = await Db.UserModuleProgresses
                .FirstOrDefaultAsync(p => p.ModuleId == ModuleId && p.UserId == userId);

            if (progress is not null)
            {
                progress.IsCompleted = true;
                progress.ProgressPercent = 100;
                progress.CompletedAt = DateTime.UtcNow;
            }
            else
            {
                // If no progress exists yet, create one
                progress = new UserModuleProgress
                {
                    ModuleId = ModuleId,
                    UserId = userId,
                    IsCompleted = true,
                    ProgressPercent = 100,
                    CompletedAt = DateTime.UtcNow
                };

                Db.UserModuleProgresses.Add(progress);
            }
        }

        await Db.SaveChangesAsync();
    }

    // Toggle button to show answers after a finished round
    private void ToggleShowAnswers()
    {
        showAnswers = !showAnswers;
    }

    // Select css class based on if answer is correct or not
    private string GetOptionCssClass(QuizQuestion question, QuizOption option)
    {
        if (!hasSubmitted || !showAnswers)
            return string.Empty;

        bool isSelected = IsSelected(question.QuizQuestionId, option.QuizOptionId);

        if (option.IsCorrect)
            return "correct";

        if (isSelected && !option.IsCorrect)
            return "wrong";

        return string.Empty;
    }

    // Resets the quiz so the user can make a new attempt
    private void RestartQuiz()
    {
        selectedAnswers.Clear();
        hasSubmitted = false;
        score = 0;
        showAnswers = false;
    }

    private void GoBack()
    {
        Nav.NavigateTo($"/modul/{ModuleId}");
    }
}