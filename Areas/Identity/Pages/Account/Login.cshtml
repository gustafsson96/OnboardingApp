@page "/login"
@model LoginModel

@{
    ViewData["Title"] = "Logga in";
}

<link rel="stylesheet" href="~/css/login.css" />

<div class="login-page">
    <div class="login-header">
        <div class="login-icon">🎓</div>
        <h1>Introduktion</h1>
        <p>Logga in för att komma åt din utbildningsportal</p>
    </div>

    <section class="login-card">
        <h2>Välkommen</h2>
        <p class="login-card-subtitle">Ange dina uppgifter för att fortsätta</p>

        <form id="account" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="login-field">
                <label asp-for="Input.Email">E-postadress</label>
                <input asp-for="Input.Email"
                       autocomplete="username"
                       aria-required="true"
                       placeholder="din.epost@foretag.se" />
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="login-field">
                <label asp-for="Input.Password">Lösenord</label>
                <input asp-for="Input.Password"
                       autocomplete="current-password"
                       aria-required="true"
                       placeholder="Ange ditt lösenord" />
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="login-checkbox">
                <label asp-for="Input.RememberMe">
                    <input asp-for="Input.RememberMe" />
                    Kom ihåg mig
                </label>
            </div>

            <button id="login-submit" type="submit" class="login-button">
                Logga in
            </button>
        </form>
    </section>

    <p class="login-help">Behöver du hjälp? Kontakta en arbetsledare.</p>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
